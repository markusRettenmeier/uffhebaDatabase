@model Sammlerplattform.Models.CollectionItemDatabase.CollectionItemRelationshipDatabase.CIRelationshipEditDTO
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["CollectionItemRelationship_Edit"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_CollectionItemRelationship"]</p>
<hr />
<form asp-action="Edit">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <input type="hidden" asp-for="Id" />
    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Edit"]
        </button>
        <a asp-action="Index" class="btn btn-dark text-white ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>