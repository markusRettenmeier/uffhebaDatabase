@model IEnumerable<Sammlerplattform.Models.CollectionItemDatabase.CollectionItemRelationshipDatabase.CIRelationshipDisplayDTO>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["CollectionItemRelationship_Index"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_CollectionItemRelationship"]</p>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />
<div class="btn-group">
    <a type="button" href="/CollectionItemRelationshipDatabase/Create" class="btn btn-success">@Localizer["Create"]</a>
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><i class="bi bi-search"></i></button>
</div>
<table class="table">
    <caption class="visually-hidden">@Localizer["CollectionItemRelationship"]</caption>
    <thead>
        <tr>
            <th>
                @Localizer["Name"]
            </th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.CollectionItemRelationshipName)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">@Localizer["Edit"]</a> |
                    @{
                        bool isDeletable = item.CollectionItemNParticipantList.Count == 0 || item.CollectionItemNPlaceList.Count == 0;
                        if (isDeletable)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id">@Localizer["Delete"]</a>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="CollectionItemRelationshipDatabase" asp-action="Index">
    <partial name="~/Views/CollectionItemRelationshipDatabase/_SearchByColumn.cshtml" />
</form>
