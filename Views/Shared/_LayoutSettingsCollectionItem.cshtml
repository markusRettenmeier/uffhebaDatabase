@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SammlerDB</title>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" media="print" onload="this.media='all'">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <partial name="_SettingsCommonHeader" />

    <div class="container page-wrap pt-2 pb-3">
        <main>
            <partial name="_StatusMessage" for="@ViewData["StatusMessage"]" />
            @RenderBody()
        </main>
    </div>

    <partial name="_SettingsCommonFooter" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    <script type="module" src="~/js/api.js" asp-append-version="true"></script>
    <script type="module" src="~/js/TranslationService.js" asp-append-version="true"></script>
    <script type="module" src="~/js/settingsCollectionItem/api.js" asp-append-version="true"></script>
    <script type="module" src="~/js/settingsCollectionItem/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>