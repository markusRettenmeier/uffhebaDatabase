@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

<header>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand fs-2" asp-controller="Home" asp-action="Frontpage">uffheba</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item dropdown">
                        <button class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" aria-expanded="false">
                            @Localizer["CollectionAreas"]
                        </button>
                        <ul class="dropdown-menu" id="appendCollectionAreasHere">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="CollectionItemRelationshipDatabase" asp-action="Index">@Localizer["CollectionItemRelationships"]</a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <button class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" aria-expanded="false">
                            @Localizer["Dimensions_Adminstration"]
                        </button>
                        <ul class="dropdown-menu">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="PlaceDatabase" asp-action="Index">@Localizer["Places"]</a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="OrganizationDatabase" asp-action="Index">@Localizer["Organizations"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="IndividualDatabase" asp-action="Index">@Localizer["Individuals"]</a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="EraDatabase" asp-action="Index">@Localizer["Eras"]</a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="CollectionAreaDatabase" asp-action="Index">@Localizer["StructureCollectionAreas"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="ConceptualRelationshipDatabase" asp-action="IndexGeneral">@Localizer["Concepts"]</a>
                    </li>
                    <li class="nav-item dropdown">
                        <button class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" aria-expanded="false">
                            @Localizer["Others"]
                        </button>
                        <ul class="dropdown-menu">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="UserSettings" asp-action="Profile">@Localizer["Profile"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="ImprovementSuggestions" asp-action="Index">@Localizer["ImprovementSuggestions"]</a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Passkey" asp-action="Logout">@Localizer["Logout"]</a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>