            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @* <li class="nav-item">
                        <a class="nav-link" asp-controller="UserSettings" asp-action="Profile">@Localizer["Profile"]</a>
                    </li> *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @Localizer["CollectionAreas"]
                        </a>
                        <ul class="dropdown-menu" style="background-color: #FFFFF0" id="appendCollectionAreasHere">
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
