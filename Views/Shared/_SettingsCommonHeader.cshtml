                                <a class="nav-link" asp-controller="SettlementDatabase" asp-action="Index">@Localizer["Settlements"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="BodyOfWaterDatabase" asp-action="Index">@Localizer["BodiesOfWater"]</a>
