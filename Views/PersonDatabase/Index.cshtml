@model IEnumerable<Sammlerplattform.Models.PersonDatabase.Person>

@{
    ViewData["Title"] = "Index";
    Layout = "_LayoutSettings";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create">Erstelle neue Persönlichkeit</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pseudonym)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PersonDescription)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Signature)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BirthYear)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DeathYear)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pseudonym)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PersonDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Signature)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BirthYear)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DeathYear)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PersonID">Ändern</a>
            </td>
        </tr>
}
    </tbody>
</table>
