@using Microsoft.AspNetCore.Mvc.Localization
@using Sammlerplattform.Models.CollectionItemDatabase.StatePreservationDatabase
@using Sammlerplattform.Models.ParticipantDatabase
@using Sammlerplattform.Models.PlaceDatabase
@model IEnumerable<Sammlerplattform.Models.CollectionItemDatabase.CollectionItemDisplayDTO>
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Frontpage"];
    
    int count = 0;
    int? topK = ViewData["TopK"] as int?;
    int? maxRows = ViewData["maxRows"] as int?;
    int? lastAmountRows = ViewData["lastAmountRows"] as int?;
}
<h1 hidden>@Localizer["CollectionItem_AllPublic"]</h1>
<form asp-for="Frontpage">
    <div class="position-relative mb-4 mt-4">
        <label for="searchFrontpage" class="visually-hidden">@Localizer["Search"]</label>
        <input name="SemanticSearchQuery" id="searchFrontpage" type="text" class="form-control search-input" placeholder="@Localizer["Search_TypeIn"]">
        <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3"></i>
    </div>
</form>

@foreach (var item in Model)
{
    <div class="row align-items-start pt-3" id="row_@count">
        @{
            <div class="col me-1" id="indexSimplePicColumn_@count">
                @for (int i = 0; i < item.CollectionItemPictureList.Count; i++)
                {
                    string imageNormal = $"/images/Normal/{item.CollectionItemPictureList[i].CollectionItemPictureID}.webp";
                    string imageSmall = $"/images/Klein/{item.CollectionItemPictureList[i].CollectionItemPictureID}.webp";
                    @if (i == 0)
                    {
                        <a class="photo" data-fancybox="gallery_@item.CollectionItemEntity.CollectionItemEntityID" href="@imageNormal" data-caption="Nummer @item.CollectionItemEntity.CollectionItemEntityID">
                            <img src="@imageSmall" width="498" height="322" alt="@Localizer["FullView", item.CollectionItemPictureList[i].CollectionItemPictureID]" id="simplePic_@count" class="indexMobile-Picture">
                            <span hidden>@Localizer["FullView", item.CollectionItemPictureList[i].CollectionItemPictureID]</span>
                        </a>
                    }
                    else
                    {
                        <a class="photo" data-fancybox="gallery_@item.CollectionItemEntity.CollectionItemEntityID" href="@imageNormal" data-caption="Nummer @item.CollectionItemEntity.CollectionItemEntityID">
                            <span hidden>@Localizer["FullView", item.CollectionItemPictureList[i].CollectionItemPictureID]</span>
                        </a>
                    }
                }
            </div>
            <div class="col indexSimple2ndColumns" id="IndexSimple2ndColumn_@count">
                <ul>
                    <li>
                        @Html.DisplayNameFor(modelItem => item.CollectionItemEntity.CollectionArea): @Html.DisplayFor(modelItem => item.CollectionItemEntity.CollectionArea.CollectionAreaName)
                    </li>                    
                    <li>
                        @Html.DisplayNameFor(modelItem => item.DisplayName): @Html.DisplayFor(modelItem => item.DisplayName)
                    </li>
                    <li>
                        @{
                            var statenameValue = item.CollectionItemEntity.StatePreservation != null ? item.CollectionItemEntity.StatePreservation.StatePreservationName : "N/A";
                        }
                        @Html.DisplayNameFor(modelItem => item.CollectionItemEntity.StatePreservation!.StatePreservationName): @statenameValue
                    </li>
                    <li>
                        @Html.DisplayNameFor(modelItem => item.CollectionItemEntity.Time): @Html.DisplayFor(modelItem => item.CollectionItemEntity.Time), @Html.DisplayNameFor(modelItem => item.CollectionItemEntity.Era): @Html.DisplayFor(modelItem => item.Era.EraName)
                    </li>
                    <li>
                        @Html.DisplayNameFor(modelItem => item.CollectionItemNParticipantList):
                        <ul>
                            @foreach (var participant in item.CollectionItemNParticipantList)
                            {
                                var vm = ParticipantViewModelHelper.FromDomainModel(participant.Participant);
                                string content = vm.Name + ", " + vm.FurtherSpecs + Localizer["As"].Value + participant.RelationType.CollectionItemRelationshipName;
                                <li>@Html.Raw(content)</li>
                            }
                        </ul>
                    </li>
                    <li>
                        @Html.DisplayNameFor(modelItem => item.CollectionItemNPlaceList):
                        <ul>
                            @foreach (var place in item.CollectionItemNPlaceList)
                            {
                                var vm = PlaceViewModelHelper.FromDomainModel(place.Place);
                                var content = vm.Toponymy + Localizer["As"].Value + place.RelationType.CollectionItemRelationshipName;
                                <li>@Html.Raw(content)</li>
                            }
                        </ul>
                    </li>
                </ul>
            </div>
            <div class="col col-2">
                <a class="btn btn-primary" asp-action="Details" asp-route-entityId="@item.CollectionItemEntity.CollectionItemEntityID">@Localizer["Details"]: @item.DisplayName</a>
            </div>
            count++;
        }
    </div>
}

@if (count == 0)
{
    @Localizer["Message_NothingFound"]
}
@if (topK is not null && topK < maxRows)
{
    <form asp-controller="Sammlung" asp-action="Kurzansicht">
        <input id="indexSimpleMaxRows" value="@maxRows" style="display: none">
        <input id="indexSimpleCurrentRows" name="topK" value="@topK" style="display: none">
        <input id="indexSimpleLastRows" value="@lastAmountRows" style="display: none">
        <div class="d-grid gap-2 mt-4 mb-4">
            <div class="transmitData" hidden></div>
            <button id="btnIndexSimpleMore" class="btn btn-primary" onclick="getMoreData()">Mehr Bilder anzeigen</button>
        </div>
    </form>
}