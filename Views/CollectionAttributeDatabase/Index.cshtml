@model Sammlerplattform.Models.CollectionAreaDatabase.CollectionArea

@{
    ViewData["Title"] = "Merkmalsverwaltung";
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<h1>@ViewData["Title"]</h1>
<h4>@Html.DisplayFor(x => x.CollectionAreaName)</h4>
<div class="btn-group" role="group" aria-label="">
    <a type="button" class="btn btn-success" asp-action="Create" asp-route-collectionAreaID="@Model.CollectionAreaID">Eintrag erstellen</a>
    <button id="tooltip-SucheOpen" class="btn btn-outline-primary" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><svg viewBox="0 0 1024 1024"><path class="path1" d="M848.471 928l-263.059-263.059c-48.941 36.706-110.118 55.059-177.412 55.059-171.294 0-312-140.706-312-312s140.706-312 312-312c171.294 0 312 140.706 312 312 0 67.294-24.471 128.471-55.059 177.412l263.059 263.059-79.529 79.529zM189.623 408.078c0 121.364 97.091 218.455 218.455 218.455s218.455-97.091 218.455-218.455c0-121.364-103.159-218.455-218.455-218.455-121.364 0-218.455 97.091-218.455 218.455z"></path></svg></button>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CollectionAttributeList.First().CollectionAttributeName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CollectionAttributeList.First().CollectionAttributeType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CollectionAttributeList.First().Required)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.CollectionAttributeList)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.CollectionAttributeName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CollectionAttributeType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Required)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-collectionAttributeID="@item.CollectionAttributeID">Ändern</a> |
                    <a asp-action="Delete" asp-route-collectionAttributeID="@item.CollectionAttributeID">Löschen</a>
                </td>
            </tr>
        }
    </tbody>
</table>
