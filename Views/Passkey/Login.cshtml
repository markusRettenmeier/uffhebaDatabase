@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = @Localizer["Login_Passkey"];
}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h1 class="mb-0">@ViewData["Title"]</h1>
            </div>
            <div class="card-body">
                <!-- WebAuthn Support Status -->
                <div id="webauthnStatus" class="mb-3"></div>

                <!-- Login Status Messages -->
                <div id="loginStatus" class="mb-3"></div>

                <!-- Info Box -->
                <div class="alert alert-info mb-4">
                    <strong>@Localizer["Login"]</strong><br>
                    @Localizer["Login_Description"]
                </div>

                <!-- Buttons -->
                <div class="d-grid gap-3 mb-4">                 
                    <button type="button" class="btn btn-outline-primary btn-lg" id="btnSearchPasskeys">
                        @Localizer["SearchAvailablePasskeys"]
                    </button>
                    <button type="button" class="btn btn-warning btn-lg" data-bs-toggle="modal" data-bs-target="#useBackupCodeModal">
                        @Localizer["Passkey_NotAvailable"]
                    </button>
                </div>

                <!-- Register Link -->
                <div class="text-center">
                    <hr class="my-4">
                    <p class="text-muted">@Localizer["NoAccountYet"]</p>
                    <a href="@Url.Action("Register", "Passkey")" class="btn btn-success">
                        @Localizer["Register"]
                    </a>
                </div>

                <!-- Security Info -->
                <div class="alert alert-info mt-4">
                    @Localizer["Passkey_Information"]
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_UseBackupCodeModal" />
<partial name="_BackupCodesModal" />