 @using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = @Localizer["Login_Passkey"];
}

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-key me-2"></i>Anmelden</h4>
                </div>
                <div class="card-body">
                    <div id="loginStatus" class="mb-3"></div>

                    <!-- Login Form -->
                    <form id="loginForm" onsubmit="return false;">
                        <div class="d-grid gap-2 mb-4">
                            <button type="button" class="btn btn-primary btn-lg"
                                    id="btnLogin" onclick="login()">
                                <i class="bi bi-key me-2"></i>@Localizer["Login"]
                            </button>
                        </div>
                        <div class="text-center">
                            <hr class="my-4">
                            <p class="text-muted">Noch keinen Account?</p>
                            <a href="@Url.Action("Register", "Passkey")" class="btn btn-success">
                                <i class="bi bi-person-plus me-2"></i>@Localizer["Register"]
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>