@model IEnumerable<Sammlerplattform.Models.ConceptualRelationshipDatabase.ConceptViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{ 
    ViewData["Title"] = @Localizer["ConceptRelation_Administration_General"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />

<div class="btn-group">
    <a type="button" href="/ConceptualRelationshipDatabase/Create" class="btn btn-success">@Localizer["Create"]</a>
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><i class="bi bi-search"></i></button>
</div>
<table class="table">
    <caption class="visually-hidden">@Localizer["ConceptRelation"]</caption>
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(Model => Model.Abbreviation)
            </th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Abbreviation)
                </td>
                <td>
                    <a asp-action="IndexSpecific" asp-route-id="@item.Id" asp-route-rootConceptId="@item.Id">@Localizer["SpecificView"]</a> | 
                    @{
                        bool isDeletable = item.SubConceptNameList.Count == 0 && item.CollectionAreaID == null;
                        if (isDeletable)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id">@Localizer["Delete"]</a>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="ConceptualRelationshipDatabase" asp-action="IndexGeneral">
    <partial name="~/Views/ConceptualRelationshipDatabase/_SearchByColumn.cshtml" />
</form>
