@model IEnumerable<Sammlerplattform.Models.ConceptualRelationshipDatabase.ConceptViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@using System.Linq

@{
    ViewData["Title"] = @Localizer["ConceptRelation_Administration_Specific"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";

    var connectedConceptIdList = ViewData["ConceptValueConceptIdList"] as List<int>;
}

<h1>@ViewData["Title"] @Model.First(x => x.IsRootConcept).Name</h1>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />
<div class="btn-group">
    <a type="button" href="/ConceptualRelationshipDatabase/Create?RootConceptID=@Model.First(x => x.IsRootConcept).Id&CollectionAreaID=@Model.First(x => x.IsRootConcept).CollectionAreaID&ConceptTypeInt=0" class="btn btn-success">@Localizer["Create"]</a>  
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><i class="bi bi-search"></i></button>
</div>
<div class="container py-4 text-center">
    <div class="row gx-5">
        <div class="col-8">
            <div class="pe-3">
                <div id="network"></div>
                <input type="hidden" asp-for="@Model.First(x => x.IsRootConcept).Id" id="RootConceptID" />
            </div>
        </div>
        <div class="col-4">
            <div class="ps-3">                
                <table class="table">
                    <caption class="visually-hidden">@Localizer["ConceptRelation"]</caption>
                    <thead>
                        <tr>
                            <th>
                                @Localizer["ConceptName"]
                            </th>
                            <th>
                                @Localizer["Abbreviation"]
                            </th>
                            <th>
                                @Localizer["ConceptType"]
                            </th>
                            <th>@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Where(x => x.RootConceptID != null))
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Name)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Abbreviation)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ConceptType)
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id">@Localizer["Edit"]</a> | 
                                    @{
                                        bool isDeletable = connectedConceptIdList == null || connectedConceptIdList.Where(x => x == item.Id).ToList().Count == 0;
                                        if (isDeletable)
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id">@Localizer["Delete"]</a>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<form asp-controller="ConceptualRelationshipDatabase" asp-action="IndexSpecific">
    <input type="hidden" name="id" value="@Model.First(x => x.IsRootConcept).Id" />
    <input type="hidden" name="rootConceptId" value="@Model.First(x => x.IsRootConcept).Id" />
    <partial name="~/Views/ConceptualRelationshipDatabase/_SearchByColumn.cshtml" />
</form>

<style>
    #network {
        width: 100%;
        height: 600px;
        border: 1px solid #ccc;
    }
</style>