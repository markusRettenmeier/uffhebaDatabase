@model Sammlerplattform.Models.ConceptualRelationshipDatabase.ConceptualRelationshipOperationParameterModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["ConceptRelation_Delete"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h3>@ViewData["Title"]</h3>

<h4>@Localizer["Delete_Confirm"]</h4>
<hr />
<dl class="row">
    <dt class = "col-sm-4">
        @Html.DisplayNameFor(model => model.Concept.ConceptName)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.Concept.ConceptName)
    </dd>
    <dt class = "col-sm-4">
        @Html.DisplayNameFor(model => model.Concept.Description)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.Concept.Description)
    </dd>
    <dt class = "col-sm-4">
        @Html.DisplayNameFor(model => model.Concept.CollectionArea)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.Concept.CollectionArea.CollectionAreaID)
    </dd>
    @if(Model.ConceptRelationList != null && Model.ConceptRelationList.Count > 0)
    {
        <dt class = "col-sm-4">
            @Localizer["ConceptRelation_Connected"]
        </dt>
        <dd class = "col-sm-10">
            <ul>
                @foreach (var item in Model.ConceptRelationList)
                {
                    <li>
                        @item.ToConcept.ConceptName (ID: @item.ToConceptID) - @Localizer["RelationType"]: @item.RelationType
                    </li>
                }
            </ul>
        </dd>
    }
</dl>
    
<form asp-action="DeleteSubmit">
    <input type="hidden" asp-for="Concept.Id" />
    <button class="btn btn-danger">@Localizer["Delete"]</button> |
    <a asp-action="Index">@Localizer["BackToList"]</a>
</form>
