@model Sammlerplattform.Models.ConceptualRelationshipDatabase.ConceptViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@using Sammlerplattform.Services.Extensions

@{
    ViewData["Title"] = Localizer["ConceptRelation_Delete"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";

    string conceptTypeDisplayName = Model.ConceptType.GetDisplayName();
}

<h1>@ViewData["Title"]</h1>
<h2>@Localizer["Delete_Confirm"]</h2>
<hr />
<div>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.Abbreviation)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Abbreviation)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.IsRootConcept)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsRootConcept)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.RootConceptID)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RootConceptID)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SubConceptNameList)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SubConceptNameList)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.CollectionAreaID)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CollectionAreaID)
        </dd>
    </dl>
    <dl class="row">
        <dt class = "col-sm-4">
            @Html.DisplayNameFor(model => model.ConceptType)
        </dt>
        <dd class = "col-sm-10">
            @conceptTypeDisplayName
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-danger btn-lg px-5">
                <i class="bi bi-check-circle"></i> @Localizer["Delete"]
            </button>
            <a asp-action="Index" class="btn btn-dark ms-2">
                @Localizer["Cancel"]
            </a>
        </div>
    </form>
</div>
