@model ConceptualRelationshipOperationParameterModel
@using Sammlerplattform.Models.ConceptualRelationshipDatabase
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["ConceptRelation_Edit"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h3>@ViewData["Title"]</h3>
<hr />
<form asp-action="EditSubmit" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Concept.CollectionAreaID" class="form-control" type="hidden">
    <input asp-for="Concept.Id" class="form-control" type="hidden">
    <div class="form-group mb-3">
        <label asp-for="Concept.ConceptName" class="control-label"></label>
        <input asp-for="Concept.ConceptName" class="form-control">
        <span asp-validation-for="Concept.ConceptName" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Concept.Description" class="control-label"></label>
        <textarea asp-for="Concept.Description" rows="3" class="form-control"></textarea>
        <span asp-validation-for="Concept.Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Relationship"]</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody id="appendConceptHere">
                @for(int i = 0; i < Model.ConceptRelationList.Count; i++)
                {
                    <tr class="conceptResultTableTr">
                        @if (Model.ConceptRelationList[i].RelationTypeInt == 0){
                            <td>Synonym für @Model.ConceptRelationList[i].ToConcept.ConceptName</td>
                        }
                        else if (Model.ConceptRelationList[i].RelationTypeInt == 1)
                        {
                            <td>Unterbegriff für @Model.ConceptRelationList[i].ToConcept.ConceptName</td>
                        }
                        else
                        {
                            <td>Kurz für @Model.ConceptRelationList[i].ToConcept.ConceptName</td>
                        }
                        <td>
                            <input type="hidden" class="form-control conceptResultTableId" asp-for="ConceptRelationList[@i].ToConceptID">
                            <input type="hidden" class="form-control conceptResultTableRelationship" asp-for="ConceptRelationList[@i].RelationTypeInt">
                            <button type="button" class="btn btn-danger btn-sm removeConceptRow">@Localizer["Remove"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ConceptModal">
            @Localizer["ConceptRelation_Add"]
        </button>
    </div>
    <button class="btn btn-success mt-2">@Localizer["Edit"]</button>
</form>

<partial name="~/Views/ConceptualRelationshipDatabase/_ModalConcept.cshtml" model="null" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}