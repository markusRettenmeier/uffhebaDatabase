@model Sammlerplattform.Models.CollectionAreaDatabase.CollectionArea

@{
    ViewData["Title"] = "Begriffsbeziehung verwalten";
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h3>@Model.CollectionAreaName: @ViewData["Title"]</h3>
<hr />
<a type="button" class="btn btn-success" asp-action="Create" asp-controller="ConceptualRelationshipDatabase" asp-route-collectionAreaID="@Model.CollectionAreaID">Eintrag erstellen</a>

@* <div class="mt-3" id="network"></div>
<input type="hidden" asp-for="CollectionAreaID"> *@

<div class="container py-4 text-center">
    <div class="row gx-5">
        <div class="col-8">
            <div class="pe-3">
                <div id="network"></div>
                <input type="hidden" asp-for="CollectionAreaID">
            </div>
        </div>
        <div class="col-4">
            <div class="ps-3">
                <table class="table">
                    <thead>
                        <tr>
                            <th>
                                @Html.DisplayNameFor(model => model.ConceptList[0].ConceptName)
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ConceptList)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ConceptName)
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ConceptID">Ändern</a> |
                                    <a asp-action="Delete" asp-route-id="@item.ConceptID">Löschen</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>



<style>
    #network {
        width: 100%;
        height: 600px;
        border: 1px solid #ccc;
    }
</style>