@using Sammlerplattform.Models.ConceptualRelationshipDatabase
@model ConceptualRelationshipOperationParameterModel

@{
    ViewData["Title"] = "Begriffsbeziehung erstellen";
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h4>@ViewData["Title"]</h4>
<hr />
<form asp-action="CreateSubmit" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Concept.CollectionAreaID" class="form-control" type="hidden" value="@ViewData["CollectionAreaID"]">
    <div class="form-group mb-3">
        <label asp-for="Concept.ConceptName" class="control-label"></label>
        <input asp-for="Concept.ConceptName" class="form-control" placeholder="z. B. Mönchziegel" />
        <span asp-validation-for="Concept.ConceptName" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Concept.Description" class="control-label">Beschreibung</label>
        <textarea asp-for="Concept.Description" rows="3" class="form-control" placeholder="Kurzbeschreibung (optional)"></textarea>
        <span asp-validation-for="Concept.Description" class="text-danger"></span>
    </div>

    @* <div>
        <label class="block text-sm font-medium">Beziehungstyp</label>
        <select id="relationType" class="mt-1 w-full border rounded px-3 py-2">
            <option value="0">SYNONYM</option>
            <option value="1">Unterbegriff</option>
            <option value="2">KANN_SEIN</option>
            <option value="KURZBEZEICHNUNG_FUER">KURZBEZEICHNUNG_FUER</option>
            <option value="IST_OBERBEGRIFF_VON">IST_OBERBEGRIFF_VON</option>
            <option value="SONSTIG">SONSTIG</option>
        </select>
    </div> *@
    <div class="mb-3">
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">Beziehung</th>
                    <th scope="col"><th>
                </tr>
            </thead>
            <tbody id="appendConceptHere">
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ConceptModal">
            Beziehung hinzufügen
        </button>
    </div>

    <hr />
    <button class="btn btn-success mt-2">Erstellen</button>
</form>

<partial name="~/Views/ConceptualRelationshipDatabase/_ModalConcept.cshtml" />
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}