@using Sammlerplattform.Models.ConceptualRelationshipDatabase
@model ConceptualRelationshipOperationParameterModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["ConceptRelation_Create"];
    Layout = "~/Views/Shared/_LayoutSettingsConceptualRelationship.cshtml";
}

<h3>@ViewData["Title"]</h3>
<hr />
<form asp-action="CreateConfirmed">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="ConceptViewModel.CollectionAreaID" class="form-control" type="hidden" value="@Model.ConceptViewModel.CollectionAreaID">
    <input asp-for="ConceptViewModel.RootConceptID" class="form-control" type="hidden" value="@Model.ConceptViewModel.RootConceptID">
    <div class="form-group mb-2">
        <label asp-for="ConceptViewModel.Name" class="control-label"></label>
        <input asp-for="ConceptViewModel.Name" class="form-control">
        <span asp-validation-for="ConceptViewModel.Name" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label asp-for="ConceptViewModel.ConceptType" class="control-label"></label>
        <select asp-for="ConceptViewModel.ConceptType"
                asp-items="Html.GetEnumSelectList<ConceptType>()"
                class="form-select">
        </select>
        <span asp-validation-for="ConceptViewModel.ConceptType" class="text-danger"></span>
    </div>
    <div class="form-group mb-2">
        <label asp-for="ConceptViewModel.Abbreviation" class="control-label"></label>
        <input asp-for="ConceptViewModel.Abbreviation" class="form-control">
        <span asp-validation-for="ConceptViewModel.Abbreviation" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Relationship"]</th>
                    <th scope="col"><th>
                </tr>
            </thead>
            <tbody id="appendConceptHere">
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ConceptModal">
            Beziehung hinzufügen
        </button>
    </div>
    <div class="form-group mb-3">
        <label asp-for="ConceptViewModel.Description" class="control-label"></label>
        <textarea asp-for="ConceptViewModel.Description" rows="3" class="form-control"></textarea>
        <span asp-validation-for="ConceptViewModel.Description" class="text-danger"></span>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Create"]
        </button>
        @if (Model.ConceptViewModel.RootConceptID != null)
        {
            <a asp-action="IndexSpecific" asp-route-id="@Model.ConceptViewModel.RootConceptID" class="btn btn-outline-secondary ms-2">
                @Localizer["Cancel"]
            </a>
        }
        else
        {
            <a asp-action="IndexGeneral" class="btn btn-outline-secondary ms-2">
                @Localizer["Cancel"]
            </a>
        }
    </div>
</form>

<partial name="~/Views/ConceptualRelationshipDatabase/_ModalConcept.cshtml" />
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}