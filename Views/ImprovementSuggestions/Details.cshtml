@using Microsoft.AspNetCore.Mvc.Localization
@using Sammlerplattform.Models.ImprovementSuggestions
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@model Sammlerplattform.Models.ImprovementSuggestions.Topic
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<div class="card" aria-labelledby="topicHeader">
<div class="card-header">
    <h1 id="topicHeader">@Model.Title</h1>
    <small>Erstellt am @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
</div>
<div class="card-body">
    <p>@Model.Content</p>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-outline-success btn-sm vote-btn" data-type="Up" data-topicId="@Model.Id">
            ↑ Plus (@(Model.VoteList?.Where(v => v.VoteType == VoteType.Up).Count() ?? 0))
        </button>
        @* <button class="btn btn-outline-danger btn-sm vote-btn" data-type="Down" data-topicId="@Model.Id">
            ↓ Minus (@(Model.VoteList?.Where(v => v.VoteType == VoteType.Down).Count() ?? 0))
        </button> *@
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id">@Localizer["Edit"]</a> |
        <a asp-action="Delete" asp-route-id="@Model.Id">@Localizer["Delete"]</a>
    </div>
    </div>
</div>

