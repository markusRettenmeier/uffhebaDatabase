@model Sammlerplattform.Models.Account.RegisterViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

<form id="registerForm" asp-controller="Account" asp-action="Register" asp-route-returnUrl="/Account/Login" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-floating">
        <input asp-for="Email" class="form-control" autocomplete="E-Mail">
        <label asp-for="Email"></label>
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-floating pt-1">
        <input asp-for="UserName" class="form-control" autocomplete="username">
        <label asp-for="UserName"></label>
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="form-floating pt-1">
        <input asp-for="Password" class="form-control" autocomplete="new-password" >
        <label asp-for="Password"></label>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="form-floating pt-1">
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password">
        <label asp-for="ConfirmPassword"></label>
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>
    <button class="w-100 btn btn-lg btn-primary mt-2">@Localizer["Register"]</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
