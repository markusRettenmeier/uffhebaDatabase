@model IEnumerable<Sammlerplattform.Models.CollectionAreaDatabase.CollectionArea>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["CollectionArea_Structure"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />
<div class="btn-group">
    <a type="button" href="/CollectionAreaDatabase/Create" class="btn btn-success">@Localizer["Create"]</a>
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()">
        <i class="bi bi-search"></i>
    </button>
</div>
<table class="table">
    <caption class="visually-hidden">@Localizer["CollectionArea"]</caption>
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CollectionAreaName)
            </th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.CollectionAreaName)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.CollectionAreaID">@Localizer["CollectionArea_Edit"]</a> |
                    @{
                        bool isDeletable = item.CollectionItemEntityList.Count == 0 && item.ConceptList.Count == 1 && item.StatePreservationList.Count == 0;
                        if(isDeletable)
                        {
                            <a asp-action="Delete" asp-route-id="@item.CollectionAreaID">@Localizer["CollectionArea_Delete"]</a> <text>|</text>
                        }
                    }
                    <a asp-action="Index" asp-controller="StatePreservationDatabase" asp-route-CollectionArea_CollectionAreaID="@item.CollectionAreaID">@Localizer["StatePreservation_Administration"]</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="CollectionAreaDatabase" asp-action="Index">
    <partial name="~/Views/CollectionAreaDatabase/_SearchByColumn.cshtml" />
</form>