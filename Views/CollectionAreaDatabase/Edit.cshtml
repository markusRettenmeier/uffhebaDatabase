@model Sammlerplattform.Models.CollectionAreaDatabase.CollectionArea
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["CollectionArea_Edit"];
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<h3>@ViewData["Title"]</h3>

<hr />
<form asp-action="EditSubmit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="CollectionAreaID" />
    <div class="form-group mb-3">
        <label asp-for="CollectionAreaName" class="control-label"></label>
        <input asp-for="CollectionAreaName" class="form-control" />
        <span asp-validation-for="CollectionAreaName" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="WikipediaUrl" class="control-label"></label>
        <input asp-for="WikipediaUrl" class="form-control" />
        <span asp-validation-for="WikipediaUrl" class="text-danger"></span>
    </div>
    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Edit"]
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

