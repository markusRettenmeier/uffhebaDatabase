@model Sammlerplattform.Models.CollectionAreaDatabase.CollectionArea

@{
    ViewData["Title"] = "Sammlungsgebiet erstellen";
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<div class="row">
    <div class="col-md-4">
        <h1>@ViewData["Title"]</h1>

        <hr />
        <form asp-action="CreateSubmit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="CollectionAreaName" class="control-label"></label>
                <input asp-for="CollectionAreaName" class="form-control" />
                <span asp-validation-for="CollectionAreaName" class="text-danger"></span>
            </div>
            <hr />
            <div class="form-group">
                <button class="btn btn-primary">Erstellen</button>
            </div>
        </form>
    </div>
</div>

