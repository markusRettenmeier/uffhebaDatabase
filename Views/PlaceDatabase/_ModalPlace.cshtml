@using Sammlerplattform.Models.PlaceDatabase
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

<div class="modal fade" id="placeModal" tabindex="-1" aria-labelledby="placeModal" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="placeModalLabel">@Localizer["Place_Select"]</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body ui-front modalBodyPlace">
                <div class="row">
                    <div class="col-sm-4 col-sm-offset-4">
                        <div class="input-group">
                            <input type="text" class="form-control inputPlaceSearch" placeholder="@Localizer["Place"]" aria-label="@Localizer["Place"]" />
                            <div>
                                <select class="form-select" id="toponymyType" asp-items="Html.GetEnumSelectList<ToponymyType>()">
                                    <option value="" selected>@Localizer["Place_Select"]</option>
                                </select>
                            </div>
                            <button class="btn btn-primary placeSearchSubmit" type="button">@Localizer["Search"]</button>
                        </div>
                    </div>
                </div>
                <table class="table" id="placeSearchResultTable">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["PlaceID"]</th>
                            <th scope="col">@Localizer["Toponymy"]</th>
                            <th scope="col">@Localizer["ToponymyType"]</th>
                            <th scope="col">@Localizer["FurtherSpecs"]</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
            </div>
        </div>
    </div>
</div>
