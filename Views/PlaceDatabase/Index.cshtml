@model IEnumerable<Place>
@using Sammlerplattform.Models.PlaceDatabase;
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Place_Administration"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />
<div class="btn-group">
    <a type="button" href="/PlaceDatabase/Create" class="btn btn-success">@Localizer["Create"]</a>
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><i class="bi bi-search"></i></button>
</div>
<table class="table">
    <caption class="visually-hidden">@Localizer["Place"]</caption>
    <thead>
        <tr>
            <th>
                @Localizer["Places"]
            </th>
            <th>
                @Localizer["ConnectedPlaces"]
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FurtherSpecs)
            </th>
            <th>
                @Localizer["Actions"]
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var vm = PlaceViewModelHelper.FromDomainModel(item);
            <tr>
                <td>@Html.Raw(vm.Toponymy)</td>
                <td>
                    @Html.Raw(vm.ConnectedPlaces)
                </td>
                <td>
                    @Html.Raw(vm.FurtherSpecs)
                </td>
                <td>
                    <a asp-action="Edit" asp-controller="PlaceDatabase" asp-route-id="@vm.PlaceID">@Localizer["Edit"]</a> | 
                    @if(vm.IsDeletable)
                    {
                        <a asp-action="Delete" asp-controller="PlaceDatabase" asp-route-id="@vm.PlaceID">@Localizer["Delete"]</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
<form asp-controller="PlaceDatabase" asp-action="Index">
    <partial name="~/Views/PlaceDatabase/_SearchByColumn.cshtml" />
</form>