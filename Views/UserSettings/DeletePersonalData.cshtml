@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = "Lösche Account";
    Layout = "_LayoutSettings";
    bool? RequirePassword = ViewData["RequirePassword"] as bool?;
}

<h3>@ViewData["Title"]</h3>
@if ((await AuthorizationService.AuthorizeAsync(User, "SubscribedDiskspacePolicy")).Succeeded)
{
    <strong>Bevor Sie den Account löschen, laden Sei zuerst Ihre Einträge herunter</strong>
    <a type="button" class="w-100 btn btn-lg btn-success" asp-action="DownloadPostcards" asp-controller="PostcardDatabase" asp-route-userId="@ViewData["userId"]" onclick="ActivateDeleteButton()">Alle Postkarten herunterladen</a>
    <hr />
}
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Das Löschen dieser Daten entfernt dauerhaft ihren Account und ihre Sammlung. Dies kann nicht rückgängig gemacht werden.</strong>
    </p>
</div>
<form asp-action="DeletePersonalDataSubmit">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    @if (RequirePassword != null && (bool)RequirePassword)
    {
        <div class="form-floating mb-3">
            <input name="Password" class="form-control" type="password" aria-required="true" placeholder="Bitte Passwort eingeben." />
            <label class="form-label">Passwort</label>
        </div>
    }
    <button class="w-100 btn btn-lg btn-danger deletePersonalData" disabled type="submit">Lösche Daten und schließe meinen Account</button>
</form>

<a asp-action="Profile" asp-controller="UserSettings">Zurück zum Profil</a>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

