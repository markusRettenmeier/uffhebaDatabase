@model Sammlerplattform.Models.UserSettings.UsingIdentityUser
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Profile"];
    Layout = "_LayoutSettings";
}

<h3>@ViewData["Title"]</h3>
<hr />

<label asp-for="Email" class="form-label"></label>
<div class="input-group mb-2">
    <a type="button" asp-action="ChangeEMail" class="btn btn-primary">@Localizer["Email_Change"]</a>
    <input asp-for="Email" class="form-control" disabled />
</div>

<label class="form-label">Password</label>
<div class="input-group mb-3">
    <a type="button" asp-action="ChangePassword" class="btn btn-primary">@Localizer["Password_Change"]</a>
    <input type="password" value="Password" class="form-control" disabled />
</div>

<form asp-action="ProfileChange">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <label asp-for="UserName" class="form-label"></label>
    <div class="input-group mb-2">
        <button class="btn btn-primary">@Localizer["UserName_Change"]</button>
        <input asp-for="UserName" class="form-control">
    </div>
    <span asp-validation-for="UserName" class="text-danger"></span>
</form>

<hr />
<div class="mb-3">
    <p>
        @Localizer["PersonalData_Notification"]
    </p>
    <a asp-action="DownloadPersonalData" class="btn btn-primary">@Localizer["PersonalData_Download"]</a>
</div>
<hr />
<div class="mb-5">
    <a asp-action="DeletePersonalData" class="btn btn-danger">@Localizer["Account_Delete"]</a>
</div>

