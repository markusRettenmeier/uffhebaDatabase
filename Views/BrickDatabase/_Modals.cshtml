<div class="modal fade" id="IsPersonExistingModal" tabindex="-1" aria-labelledby="IsPersonExistingModal" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="PersonModalLabel">Wähle die Person</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body ui-front">
                <div class="row">
                    <div class="col-sm-12 col-sm-offset-12">
                        <div class="input-group">
                            <input type="text" class="form-control" id="inputPersonNameSearch" placeholder="Name" aria-label="Name der Person">
                            <input type="text" class="form-control" id="inputPersonSignatureSearch" placeholder="Signatur" aria-label="Zeichen">
                            <input type="text" class="form-control" id="inputPersonPseudonymSearch" placeholder="Pseudonym" aria-label="Pseudonym">
                            <button class="btn btn-primary ExistingPersonSearchSubmit" type="button">Suchen</button>
                        </div>
                    </div>
                </div>
                <table class="table" id="personSearchResultTable">
                    <thead>
                        <tr>
                            <th scope="col">@Html.DisplayNameFor(x => x.Person.PersonID)</th>
                            <th scope="col">@Html.DisplayNameFor(x => x.Person.Name)</th>
                            <th scope="col">@Html.DisplayNameFor(x => x.Person.Signature)</th>
                            <th scope="col">@Html.DisplayNameFor(x => x.Person.Pseudonym)</th>
                            <th scope="col">Aktionen</th>
                        </tr>
                    </thead>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
            </div>
        </div>
    </div>
</div>

