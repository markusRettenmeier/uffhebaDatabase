                        <thead>
                            <tr>
                                <th scope="col">@Html.DisplayNameFor(x => x.Person.PersonID)</th>
                                <th scope="col">@Html.DisplayNameFor(x => x.Person.Name)</th>
                                <th scope="col">@Html.DisplayNameFor(x => x.Person.Signature)</th>
                                <th scope="col">@Html.DisplayNameFor(x => x.Person.Pseudonym)</th>
                                <th scope="col">@Html.DisplayNameFor(x => x.BrickEntityNPersonList[0].Relationship)</th>
                                <th scope="col">Weitere Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="personResultTableBody">
                            @if (Model != null)
                            {
                                @foreach (var brickEntityNPerson in Model.BrickEntityNPersonList)
                                {
