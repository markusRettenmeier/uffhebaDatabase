        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCitys" aria-expanded="false" aria-controls="collapseCitys">
                    Orte
                </button>
            </h2>
            <div id="collapseCitys" class="accordion-collapse collapse" data-bs-parent="#accordionBrick">
                <div class="accordion-body">
                    <table class="table" id="cityTable">
                        <thead>
                            <tr>
                                <th scope="col">Orts_ID</th>
                                <th scope="col">Ort</th>
                                <th scope="col">PLZ</th>
                                <th scope="col">Beiname</th>
                                <th scope="col">Geographischer Bezug</th>
                                <th scope="col">Bezug</th>
                                <th scope="col">Weitere Aktionen</th>
                            </tr>
                        </thead>
                        <tbody id="cityResultTableBody">
                            @if (Model != null)
                            {
                                @foreach (var bnc in Model.BrickEntityNCityList)     
                                {
                                    string? oeconym = bnc.City?.CityNOeconymList.Where(x => x.CurrentName).Select(x => x.Oeconym.OeconymName).FirstOrDefault();
                                    string postalcode = string.Empty;
                                    if (bnc.City?.PostalcodeList != null)
                                    {
                                        foreach(var postalcode1 in bnc.City.PostalcodeList)
                                        {
                                                postalcode += postalcode1.PostalcodeNumber + ", ";
                                        }
                                    }
                                    <tr id="cityResultTableTr_@cityCount" class="cityResultTableTr">
                                        <td scope="col">
                                            @bnc.CityID
                                            <input type="hidden" asp-for="BrickEntityNCityList[cityCount].CityID" class="cityResultTableId">
                                        </td>
                                        <td scope="col">@oeconym</td>
                                        <td scope="col">@postalcode</td>
                                        <td scope="col">@bnc.City?.Byname</td>
                                        <td scope="col">@bnc.City?.Geography?.GeographyName</td>
                                        <td scope="col"><input class="form-control cityResultTableRelationship" asp-for="BrickEntityNCityList[cityCount].Relationship" required></td>
                                        <td scope="col">
                                            <button type="button" class="btn btn-outline-danger" onclick="removeCity(@cityCount)">Entfernen</button>
                                        </td>
                                    </tr>
                                    cityCount++;
                                }
                            }
                        </tbody>
                    </table>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#IsCityExistingModal">
                        Ort hinzufügen
                    </button>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingAdministration">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAdministration" aria-expanded="false" aria-controls="collapseAdministration">
                    Verwaltung
