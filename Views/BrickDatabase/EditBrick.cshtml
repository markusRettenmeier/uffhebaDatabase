                                            </td>
                                            <td scope="col" id="personName">@brickEntityNPerson.Person.Name</td>
                                            <td scope="col" id="personSignature">@brickEntityNPerson.Person.Signature</td>
                                            <td scope="col" id="personPseudonym">@brickEntityNPerson.Person.Pseudonym</td>
                                            <td scope="col"><input class="form-control personResultTableRelationship" asp-for="BrickEntityNPersonList[personCount].Relationship" required></td>
                                            <td scope="col">
                                                <button type="button" class="btn btn-outline-danger" onclick="removePerson(@personCount)">Entfernen</button>
                                            </td>
                                        </tr>
                                        personCount++;
                                    }
                                }
                            }
                        </tbody>
                    </table>
