                    <div class="form-group">
                        <label asp-for="BrickEntity.FilingLocation"></label>
                        <input asp-for="BrickEntity.FilingLocation" class="form-control" />
                        <span asp-validation-for="BrickEntity.FilingLocation" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BrickEntity.Price"></label>
                        <input asp-for="BrickEntity.Price" class="form-control">
                        <span asp-validation-for="BrickEntity.Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BrickEntity.Comment"></label>
                        <input asp-for="BrickEntity.Comment" class="form-control">
                        <span asp-validation-for="BrickEntity.Comment" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BrickEntity.TransferFromOwner"></label>
                        <input asp-for="BrickEntity.TransferFromOwner" class="form-control" />
                        <span asp-validation-for="BrickEntity.TransferFromOwner" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-success mt-2">Ändern</button>
</form>

