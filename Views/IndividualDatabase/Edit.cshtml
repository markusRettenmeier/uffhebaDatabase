@model IndividualEditDTO
@using Sammlerplattform.Models.PartyDatabase.IndividualDatabase
@using Sammlerplattform.Models.PlaceDatabase
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Individual_Edit"];
    Layout = "~/Views/Shared/_LayoutSettingsPlace.cshtml";
    
    List<Place>? connectedPlaceList = ViewData["ConnectedPlaces"] as List<Place>;

}

<h3>@ViewData["Title"]</h3>
<hr />
<form asp-action="Edit" >
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="PartyID">
    <input type="hidden" asp-for="PartyTypeInt">
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Pseudonym" class="control-label"></label>
        <input asp-for="Pseudonym" class="form-control" />
        <span asp-validation-for="Pseudonym" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Signature" class="control-label"></label>
        <input asp-for="Signature" class="form-control" />
        <span asp-validation-for="Signature" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@Localizer["PlaceName"]</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody id="appendPlaceHere">                        
                @if (connectedPlaceList != null)
                {
                    for (int i = 0; i < connectedPlaceList.Count; i++)
                    {
                        var vm = PlaceViewModelHelper.FromDomainModel(connectedPlaceList[i]);
                        <tr class="placeTableRow">
                            <td>@Html.Raw(vm.Toponymy)</td>
                            <td>
                                <input type="hidden" name="PlaceList[@i].PlaceID" value="@vm.PlaceID">
                                <button type="button" class="btn btn-danger btn-sm removePlaceRow">@Localizer["Remove"]</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#placeModal">
            @Localizer["Place_Add"]
        </button>
    </div>
    <div class="form-group mb-3">
        <label asp-for="WikipediaUrl" class="control-label"></label>
        <input asp-for="WikipediaUrl" class="form-control" />
        <span asp-validation-for="WikipediaUrl" class="text-danger"></span>
    </div>
    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Edit"]
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>

<partial name="~/Views/PlaceDatabase/_ModalPlace.cshtml" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

