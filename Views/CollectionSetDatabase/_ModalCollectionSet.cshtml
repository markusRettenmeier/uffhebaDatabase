@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

<div class="modal fade" id="CollectionSetModal" tabindex="-1" aria-labelledby="CollectionSetModal" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="CollectionSetModalLabel">@Localizer["CollectionSet_Select"]</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body ui-front">
                <div class="row">
                    <div class="col-sm-4 col-sm-offset-4">
                        <div class="input-group">
                            <input type="text" class="form-control" id="inputCollectionSetNameSearch" placeholder="@Localizer["CollectionSet"]" aria-label="@Localizer["CollectionSet"]" />
                            <button class="btn btn-primary eraSearchSubmit" type="button">@Localizer["Search"]</button>
                        </div>
                    </div>
                </div>
                <table class="table" id="eraSearchResultTable">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["CollectionSetId"]</th>
                            <th scope="col">@Localizer["CollectionSetName"]</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
            </div>
        </div>
    </div>
</div>