        <div class="accordion-item">
            <h2 class="accordion-header" id="headingPublisher">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePublisher" aria-expanded="false" aria-controls="collapsePublisher">
                    Verlage
                </button>
            </h2>
            <div id="collapsePublisher" class="accordion-collapse collapse" aria-labelledby="headingPublisher" data-bs-parent="#accordionExample">
                <div class="accordion-body">
                    <div class="row">
                        <div class="col FirstManufactory" style="display: none">
                            <div class="input-group">
                                <input type="hidden" class="form-control dataSet storeInput InputManufactoryID PublisherCreateEdit" id="InputManufactoryID_0" placeholder="Verlagsnummer" aria-label="Verlagsnummer" />
                                <input class="form-control storeInput InputManufactory" id="InputManufactory_0" placeholder="Verlag" aria-label="Verlag" />
                                <select class="form-select dataSet storeInput TownOfManufactorySelect PublisherCreateEdit" aria-label="Verlagsort" id="CityOfManufactorySelect_0">
                                </select>
                                <span asp-validation-for="Manufactory.Manufactory_ID" class="text-danger"></span>
                                <button type="button" class="form-control btn btn-danger DeleteManufactory" id="DeleteManufactory_0">Verlag von Karte entfernen</button>
                            </div>
                        </div>
                        <div class="AppendManufactoryHere">
                            @if (Model != null && Model.ManufactoryTupleList != null)
                            {
                                int manCount = 0;
                                foreach (var pemc in Model.ManufactoryTupleList)
                                {
                                    manCount++;
                                    <div class="col" id="DivManufactory_@manCount">
                                        <div class="input-group">
                                            <input type="hidden" class="form-control dataSet storeInput InputManufactoryID PublisherCreateEdit" id="InputManufactoryID_@manCount" value="@pemc.publisher.Manufactory_ID" placeholder="Verlagsnummer" aria-label="Verlagsnummer" />
                                            <input class="form-control storeInput InputManufactory" id="InputManufactory_@manCount" value="@pemc.publisher.ManufactoryName" placeholder="Verlag" aria-label="Verlag" />
                                            <select class="form-select dataSet storeInput TownOfManufactorySelect PublisherCreateEdit" aria-label="Verlagsort" id="CityOfManufactorySelect_0">
                                                @if (pemc.city != null && pemc.city.City_ID > 0)
                                                {
                                                    <option value="0"></option>
                                                }
                                                else
                                                {
                                                    <option value="0" selected></option>
                                                }
                                                @foreach (City cl in pemc.cityList)
                                                {
                                                    string geographyName = string.Empty;
                                                    if (cl.Geography!= null && !string.IsNullOrEmpty(cl.Geography.GeographyName))
                                                        geographyName = " (" + cl.Geography.GeographyName + ")";
                                                    var oeconym = cl.CityNOeconymICollection.Where(x => x.CurrentName).Select(x => x.Oeconym.OeconymName).FirstOrDefault();
                                                    if (oeconym == null)
                                                        continue;
                                                    if (pemc.city != null && cl.City_ID == pemc.city.City_ID)
                                                    {
                                                        <option value="@cl.City_ID" selected>@oeconym @geographyName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@cl.City_ID">@oeconym @geographyName</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="Manufactory.Manufactory_ID" class="text-danger"></span>
                                            <button type="button" class="form-control btn btn-danger DeleteManufactory" id="@manCount">Verlag von Karte entfernen</button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="col">
                            <div class="btn-group" role="group" aria-label="Basic example">
                                <button type="button" class="btn btn-primary AddMoreManufactorys">Der Karte mehr Verlage hinzufügen</button>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#CreateManufactoryModal">
                                    Hersteller-Schnellerfassung
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="form-group">
        <input type="submit" value="Ändern" class="btn btn-success mt-2" onclick="ConcludeLists()" />
    </div>
</form>
    
