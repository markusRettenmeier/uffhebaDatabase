@using Sammlerplattform.Models.ParticipantDatabase
@using Sammlerplattform.Models.PlaceDatabase
@model Sammlerplattform.Models.CollectionItemDatabase.CollectionItemDisplayDTO
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

<div class="row">
    @if (Model.CollectionItemPictureList.Count > 0)
    {
        @for (int i = 0; i < Model.CollectionItemPictureList.Count; i++)
        {
            string pathPicture = @"/images/Normal/" + Model.CollectionItemPictureList[i].CollectionItemPictureID + ".webp";
            <div class="col">
                <div class="card" style="width: 30rem;">
                    <img src="@pathPicture" class="card-img-top" alt="@Model.CollectionItemPictureList[i].PerspectiveDisplay @Localizer["Of"] Model.CollectionItemPictureList[i].CollectionItemPictureID">
                    <div class="card-body">
                        <p class="card-text" id="pictureHeader_@i">@Model.CollectionItemPictureList[i].PerspectiveDisplay</p>
                    </div>
                </div>
            </div>
        }
    }
</div>
<dl class="row">
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.UniqueName)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.UniqueName)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.PersonalIdentificationNumber)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.PersonalIdentificationNumber)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.FilingLocation)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.FilingLocation)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.DeliveryPrice)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.DeliveryPrice)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.DeliveryDate)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.DeliveryDate)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.DeliveryAdress)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.DeliveryAdress)
    </dd>
    <dt class="col-sm-10">
        @{
            bool isFake = Model.Fake;
        }
        <span>@(isFake ? "✔" : "✘")</span>  @Html.DisplayNameFor(model => model.Fake)
    </dt>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Width)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Width)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Height)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Height)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Length)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Length)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Diameter)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Diameter)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Weight)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Weight)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Comment)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Comment)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.StatePreservationName)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.StatePreservationName)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.ExactYear)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.ExactYear)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.StartYear)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.StartYear)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.EndYear)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.EndYear)
    </dd>
    <dt class="col-sm-10">
        @{bool isApproximate = Model.IsApproximate;}
        <span>@(isApproximate ? "✔" : "✘")</span> @Html.DisplayNameFor(model => model.IsApproximate)
    </dt>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.EraName)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.EraName)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.Inscription)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Inscription)
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.CollectionAreaName)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.CollectionAreaName)
    </dd>
    <dt class="col-sm-4">
        @Localizer["Concepts"]
    </dt>
    @foreach (var itemValue in Model.ConceptValueList)
    {
        @if (itemValue.ValueBool == null)
        {
            <dd class="col-sm-10">
                @itemValue.ConceptName: @itemValue.ValueDisplay
            </dd>
        }
        else {
            <dd class="col-sm-10">
                @itemValue.ValueDisplay
            </dd>
        }
    }
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.CollectionItemNParticipantList)
    </dt>
    <dd class="col-sm-10">
        @foreach (var collItemNParticipant in Model.CollectionItemNParticipantList)
        {
            var vm = ParticipantViewModelHelper.FromDomainModel(collItemNParticipant);
            var text = vm.Name + ", " + @vm.FurtherSpecs + Localizer["As"].Value + collItemNParticipant.RelationshipName;
            @Html.Raw(text)
            <br />
        }
    </dd>
    <dt class="col-sm-4">
        @Html.DisplayNameFor(model => model.CollectionItemNPlaceList)
    </dt>
    <dd class="col-sm-10">
        @foreach (var collItemNPlace in Model.CollectionItemNPlaceList)
        {
            var vm = PlaceViewModelHelper.FromDomainModel(collItemNPlace);
            var text = vm.Toponymy + ", " + @vm.FurtherSpecs + Localizer["As"].Value + collItemNPlace.RelationshipName;
            @Html.Raw(text)
            <br />
        }
    </dd>
</dl>