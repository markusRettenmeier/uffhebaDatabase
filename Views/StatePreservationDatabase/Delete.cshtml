@model StatePreservationDisplayDTO
@using Microsoft.AspNetCore.Mvc.Localization
@using Sammlerplattform.Models.CollectionItemDatabase.StatePreservationDatabase
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["StatePreservation_Delete"];
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";

    string? collectionAreaName = ViewData["CollectionAreaName"] as string; 
}

<h1>@ViewData["Title"]</h1>
<h2>@Localizer["Delete_Confirm"]</h2>
<hr />
<dl class="row">
    <dt class = "col-sm-2">
        @Html.DisplayNameFor(model => model.Name)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.Name)
    </dd>
    <dt class = "col-sm-2">
        @Localizer["CollectionArea"]
    </dt>
    <dd class = "col-sm-10">
        @collectionAreaName
    </dd>
    <dt class = "col-sm-2">
        @Html.DisplayNameFor(model => model.SortingOrder)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.SortingOrder)
    </dd>
</dl>
    
<form asp-action="Delete">
    <input type="hidden" asp-for="CollectionAreaID" />
    <input type="hidden" asp-for="Id" />
    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-danger btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Delete"]
        </button>
        <a asp-action="Index" class="btn btn-dark text-white ms-2" asp-route-CollectionArea_CollectionAreaID="@Model.CollectionAreaID">
            @Localizer["Cancel"]
        </a>
    </div>
</form>