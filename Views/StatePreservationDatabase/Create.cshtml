@model StatePreservation
@using Microsoft.AspNetCore.Mvc.Localization
@using Sammlerplattform.Models.CollectionItemDatabase.StatePreservationDatabase
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["StatePreservation_Create"];
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<h3>@ViewData["Title"]</h3>
<hr />
<form asp-action="CreateSubmit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="CollectionAreaID" class="form-control">
    <div class="form-group">
        <label asp-for="StatePreservationName" class="control-label"></label>
        <input asp-for="StatePreservationName" class="form-control" />
        <span asp-validation-for="StatePreservationName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SortingOrder" class="control-label"></label>
        <input asp-for="SortingOrder" class="form-control" />
        <span asp-validation-for="SortingOrder" class="text-danger"></span>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Create"]
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>

<div>
    <a asp-action="Index" asp-route-CollectionArea_CollectionAreaID="@Model.CollectionAreaID">@Localizer["BackToList"]</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

