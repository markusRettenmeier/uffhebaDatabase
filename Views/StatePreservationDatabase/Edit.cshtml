@model StatePreservationEditDTO
@using Microsoft.AspNetCore.Mvc.Localization
@using Sammlerplattform.Models.CollectionItemDatabase.StatePreservationDatabase
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["StatePreservation_Edit"];
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<h1>@ViewData["Title"]</h1>
<hr />
<form asp-action="Edit">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="CollectionAreaID" class="form-control" value="@Model.CollectionAreaID" />
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" aria-required="true" aria-invalid="false" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SortingOrder" class="control-label"></label>
        <input asp-for="SortingOrder" class="form-control" />
        <span asp-validation-for="SortingOrder" class="text-danger"></span>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Edit"]
        </button>
        <a asp-action="Index" class="btn btn-dark text-white ms-2" asp-route-CollectionArea_CollectionAreaID="@Model.CollectionAreaID">
            @Localizer["Cancel"]
        </a>
    </div>
</form>