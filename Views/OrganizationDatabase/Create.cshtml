@model OrganizationOperationParameterModel
@using Sammlerplattform.Models.PartyDatabase.OrganizationDatabase
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Organization_Create"];
    Layout = "~/Views/Shared/_LayoutSettingsParty.cshtml";
}

<h4>@ViewData["Title"]</h4>
<hr />
<form asp-action="CreateSubmit" asp-controller="OrganizationDatabase">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Party.PartyTypeInt" type="hidden" value="0" />
    <div class="form-group">
        <label asp-for="Party.PartyName" class="control-label"></label>
        <input asp-for="Party.PartyName" class="form-control" />
        <span asp-validation-for="Party.PartyName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Organization.OrganizationTypeInt" class="control-label"></label>
        <select asp-for="Organization.OrganizationTypeEnum"
                asp-items="Html.GetEnumSelectList<OrganizationType>()"
                class="form-select">
            <option value="" selected>@Localizer["Organization_Select"]</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="Organization.ProductionFacility" class="control-label"></label>
        <select asp-for="Organization.ProductionFacilityID" id="inputProductionFacilityID" class="form-select" aria-label="Production Facility"></select>
    </div>
    <div class="mb-3">
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@Localizer["PlaceName"]</th>
                    <th scope="col">@Localizer["FurtherSpecs"]</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody id="appendPlaceHere">
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#placeModal">
            @Localizer["Place_Add"]
        </button>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Party.WikipediaUrl" class="control-label"></label>
        <input asp-for="Party.WikipediaUrl" class="form-control" />
        <span asp-validation-for="Party.WikipediaUrl" class="text-danger"></span>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Create"]
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>

<partial name="~/Views/PlaceDatabase/_ModalPlace.cshtml" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

