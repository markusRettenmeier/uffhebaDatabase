@model OrganizationEditDTO
@using Sammlerplattform.Models.EraDatabase
@using Sammlerplattform.Models.ParticipantDatabase.OrganizationDatabase
@using Sammlerplattform.Models.PlaceDatabase
@using Sammlerplattform.Models.ParticipantDatabase
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Organization_Edit"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";

    List<PlaceDisplayDTO>? connectedPlaceList = ViewData["ConnectedPlaces"] as List<PlaceDisplayDTO>;
    List<EraDisplayDTO>? connectedEraList = ViewData["ConnectedEras"] as List<EraDisplayDTO>;
}

<h1>@ViewData["Title"]</h1>
<hr />
<form asp-action="Edit" asp-controller="OrganizationDatabase">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="Id" type="hidden" />
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" aria-required="true" aria-invalid="false" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Industry" class="control-label"></label>
        <input asp-for="Industry" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="WikipediaUrl" class="control-label"></label>
        <input asp-for="WikipediaUrl" class="form-control" />
        <span asp-validation-for="WikipediaUrl" class="text-danger"></span>
    </div>
    <hr />
    <h2>@Localizer["ConnectedPlaces"]</h2>
    <div class="mb-3">
        <table class="table">
            <caption class="visually-hidden">@Localizer["ConnectedPlaces"]</caption>
            <thead>
                <tr>
                    <th scope="col">@Localizer["Name"]</th>
                    <th scope="col">@Localizer["FurtherSpecs"]</th>
                    <th scope="col">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="appendPlaceHere" aria-live="polite" aria-relevant="additions">
                @if (connectedPlaceList != null)
                {
                    @for (int i = 0; i < connectedPlaceList.Count; i++)
                    {
                        var vm = PlaceViewModelHelper.FromDomainModel(connectedPlaceList[i]);
                        <tr class="placeTableTr">
                            <td>
                                @Html.Raw(vm.Toponymy)
                            </td>
                            <td>
                                @Html.Raw(vm.FurtherSpecs)
                            </td>
                            <td>
                                <input type="hidden" name="ConnectedPlaceList[@i].PlaceID" value="@vm.PlaceID" />
                                <button type="button" class="btn btn-danger btn-sm removePlace">@Localizer["Remove"]</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#placeModal" aria-haspopup="dialog" aria-controls="placeModal">
            @Localizer["Relation_Add"]
        </button>
    </div>
    <hr />
    <h2>@Localizer["ConnectedEras"]</h2>
    <div class="mb-3">
        <table class="table">
            <caption class="visually-hidden">@Localizer["ConnectedEras"]</caption>
            <thead>
                <tr>
                    <th scope="col">@Localizer["EraName"]</th>
                    <th scope="col">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="appendEraHere" aria-live="polite" aria-relevant="additions">
                @if (connectedEraList != null)
                {
                    @for (int i = 0; i < connectedEraList.Count; i++)
                    {
                        <tr class="eraResultTableTr">
                            <td>
                                @Html.Raw(connectedEraList[i].EraName)
                            </td>
                            <td>
                                <input type="hidden" name="ConnectedEraList[@i].EraID" value="@connectedEraList[@i].EraID" />
                                <button type="button" class="btn btn-danger btn-sm removeEra">@Localizer["Remove"]</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#EraModal" aria-haspopup="dialog" aria-controls="EraModal">
            @Localizer["Era_Add"]
        </button>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-check-circle"></i> @Localizer["Edit"]
        </button>
        <a asp-action="Index" class="btn btn-dark text-white ms-2">
            @Localizer["Cancel"]
        </a>
    </div>
</form>

<partial name="~/Views/PlaceDatabase/_ModalPlace.cshtml" />
<partial name="~/Views/EraDatabase/_ModalEra.cshtml" />

@*Hier notwendig, da dynamische asp-validation in addParticipant und addPlace durchgeführt wird*@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}