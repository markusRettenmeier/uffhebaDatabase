@model IEnumerable<Party>
@using Sammlerplattform.Models.PartyDatabase;

@{
    ViewData["Title"] = "Organisationsverwaltung";
    Layout = "~/Views/Shared/_LayoutSettingsParty.cshtml";
}

<h1>@ViewData["Title"]</h1>

<div class="btn-group" role="group" aria-label="">
    <a type="button" class="btn btn-success" asp-action="Create" asp-controller="OrganizationDatabase">Eintrag erstellen</a>
    <button id="tooltip-SucheOpen" class="btn btn-outline-primary" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><svg viewBox="0 0 1024 1024"><path class="path1" d="M848.471 928l-263.059-263.059c-48.941 36.706-110.118 55.059-177.412 55.059-171.294 0-312-140.706-312-312s140.706-312 312-312c171.294 0 312 140.706 312 312 0 67.294-24.471 128.471-55.059 177.412l263.059 263.059-79.529 79.529zM189.623 408.078c0 121.364 97.091 218.455 218.455 218.455s218.455-97.091 218.455-218.455c0-121.364-103.159-218.455-218.455-218.455-121.364 0-218.455 97.091-218.455 218.455z"></path></svg></button>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PartyName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PartyDescription)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Organization!.OrganizationTypeEnum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Organization!.ProductionFacility)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PlaceList)
            </th>
            <th>Aktionen</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var vm = PartyViewModelHelper.FromDomainModel(item);
            <tr>
                <td>@Html.Raw(vm.Name)</td>
                <td>@Html.Raw(vm.Description)</td>
                <td>@Html.Raw(vm.OrganizationType)</td>
                <td>@Html.Raw(vm.ProductionFacility)</td>
                <td>@Html.Raw(vm.Places)</td>
                <td>
                    <a asp-action="Edit" asp-asp-controller="OrganizationDatabase" asp-route-id="@item.PartyID">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="OrganizationDatabase" asp-action="Index">
    <partial name="~/Views/PartyDatabase/_SearchByColumn.cshtml" />
</form>
