@model Sammlerplattform.Models.EraDatabase.Era
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Era_Create"];
    Layout = "~/Views/Shared/_LayoutSettings.cshtml";
}

<div class="row">
    <div class="col-md-8">
        <h3>@ViewData["Title"]</h3>
        <hr />
        <form asp-action="CreateEra">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="EraName" class="control-label"></label>
                <input asp-for="EraName" class="form-control">
                <span asp-validation-for="EraName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="StartYear" class="control-label"></label>
                <input asp-for="StartYear" class="form-control">
                <span asp-validation-for="StartYear" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EndYear" class="control-label"></label>
                <input asp-for="EndYear" class="form-control">
                <span asp-validation-for="EndYear" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="WikipediaUrl" class="control-label"></label>
                <input asp-for="WikipediaUrl" class="form-control">
                <span asp-validation-for="WikipediaUrl" class="text-danger"></span>
            </div>
            <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> @Localizer["Create"]
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    @Localizer["Cancel"]
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

