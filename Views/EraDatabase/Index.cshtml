@model IEnumerable<Sammlerplattform.Models.EraDatabase.EraDisplayDTO>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Sammlerplattform.Resources.SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Era_Administration"];
    Layout = "~/Views/Shared/_LayoutSettingsDimensions.cshtml";    
}

<h1>@ViewData["Title"]</h1>
<p>@Localizer["Info_Delete_NotAllowed"]</p>
<hr />

<div class="btn-group">
    <a type="button" href="/EraDatabase/Create" class="btn btn-success">@Localizer["Create"]</a>
    <button id="openSidebarButton" class="btn btn-info" data-toggle="tooltip" data-placement="under" title="Öffne Suchleiste" type="button" onclick="openNav()"><i class="bi bi-search"></i></button>
</div>
<table class="table">
    <caption class="visually-hidden">@Localizer["Era"]</caption>
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EraName)
            </th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.EraName)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.EraID">@Localizer["Edit"]</a> | 
                    @{
                        bool isDeletable = item.CollectionItemEntityList.Count == 0;
                        if(isDeletable)
                        {
                            <a asp-action="Delete" asp-route-id="@item.EraID">@Localizer["Delete"]</a>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="EraDatabase" asp-action="Index">
    <partial name="~/Views/EraDatabase/_SearchByColumn.cshtml" />
</form>
